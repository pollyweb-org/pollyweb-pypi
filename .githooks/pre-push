#!/usr/bin/env sh

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTHON_BIN="python3"
if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$REPO_ROOT/.venv/bin/python"
elif ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  PYTHON_BIN="python"
fi

echo "Running test suite before push..."

if ! (cd "$REPO_ROOT" && "$PYTHON_BIN" -m pytest -m "not live_dns"); then
  echo ""
  echo "Push blocked: tests failed."
  exit 1
fi

echo "Running security scans before push..."

if ! (cd "$REPO_ROOT" && ./tools/run-security-scans.sh); then
  echo ""
  echo "Push blocked: security scans failed."
  exit 1
fi

echo "Tests and security scans passed. Continuing push."
