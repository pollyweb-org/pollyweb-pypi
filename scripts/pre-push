#!/usr/bin/env bash
#
# pre-push hook: block push when pip-audit finds known vulnerabilities
# in the project's dependencies.
#
# Runs pip-audit against pyproject.toml / setup.py in the repo root.
# Exit code 0 = no issues, push proceeds.
# Non-zero  = vulnerabilities found, push is blocked.
#
# Install: ln -sf ../../scripts/pre-push .git/hooks/pre-push

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "==> Running security audit before push..."

# Locate pip-audit (pipx installs to ~/.local/bin which may not be on PATH)
PIP_AUDIT="${HOME}/.local/bin/pip-audit"
if ! command -v pip-audit &>/dev/null; then
    if [ -x "$PIP_AUDIT" ]; then
        : # use the full path below
    else
        echo "ERROR: pip-audit is not installed."
        echo "Install it with:  pipx install pip-audit"
        exit 1
    fi
else
    PIP_AUDIT="pip-audit"
fi

# Run pip-audit against the project
if [ -f "$REPO_ROOT/pyproject.toml" ] || [ -f "$REPO_ROOT/setup.py" ]; then
    if ! "$PIP_AUDIT" --strict --desc on -r <(cd "$REPO_ROOT" && python -c "
import configparser, ast, sys, tomllib, pathlib

deps = []
pyproject = pathlib.Path('pyproject.toml')
setup_py = pathlib.Path('setup.py')

if pyproject.exists():
    with open(pyproject, 'rb') as f:
        data = tomllib.load(f)
    deps.extend(data.get('project', {}).get('dependencies', []))

if not deps and setup_py.exists():
    import re
    content = setup_py.read_text()
    m = re.search(r'install_requires\s*=\s*\[(.*?)\]', content, re.DOTALL)
    if m:
        deps.extend(re.findall(r'\"([^\"]+)\"|\'([^\']+)\'', m.group(1)))
        deps = [d[0] or d[1] for d in deps]

for d in deps:
    print(d)
") 2>&1; then
        echo ""
        echo "PUSH BLOCKED: Security vulnerabilities found in dependencies."
        echo "Fix the issues above before pushing."
        exit 1
    fi
else
    echo "WARNING: No pyproject.toml or setup.py found. Skipping audit."
fi

echo "==> Security audit passed. Proceeding with push."
exit 0
