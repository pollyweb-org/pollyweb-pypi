#!/usr/bin/env bash
#
# pre-push hook: run tests and block push when failures or known
# dependency vulnerabilities are found.
#
# Runs pytest, then pip-audit against pyproject.toml / setup.py in the
# repo root.
# Exit code 0 = checks passed, push proceeds.
# Non-zero  = test failures or vulnerabilities found, push is blocked.
#
# Install: ln -sf ../../scripts/pre-push .git/hooks/pre-push

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTHON_BIN="python3"
if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON_BIN="$REPO_ROOT/.venv/bin/python"
elif ! command -v "$PYTHON_BIN" &>/dev/null; then
    PYTHON_BIN="python"
fi

echo "==> Running test suite before push..."
if ! "$PYTHON_BIN" -m pytest --version &>/dev/null; then
    echo "ERROR: pytest is not installed in $PYTHON_BIN."
    echo "Install it with:  python -m pip install pytest"
    exit 1
fi

if ! (cd "$REPO_ROOT" && "$PYTHON_BIN" -m pytest); then
    echo ""
    echo "PUSH BLOCKED: Test suite failed."
    echo "Fix failing tests before pushing."
    exit 1
fi

echo "==> Running security audit before push..."

if ! "$PYTHON_BIN" -m pip_audit --version &>/dev/null; then
    echo "ERROR: pip-audit is not installed in $PYTHON_BIN."
    echo "Install it with:  $PYTHON_BIN -m pip install pip-audit"
    exit 1
fi

# Run pip-audit against the project
if [ -f "$REPO_ROOT/pyproject.toml" ] || [ -f "$REPO_ROOT/setup.py" ]; then
    if ! "$PYTHON_BIN" -m pip_audit --strict --desc on -r <(cd "$REPO_ROOT" && "$PYTHON_BIN" -c "
import configparser, ast, sys, tomllib, pathlib

deps = []
pyproject = pathlib.Path('pyproject.toml')
setup_py = pathlib.Path('setup.py')

if pyproject.exists():
    with open(pyproject, 'rb') as f:
        data = tomllib.load(f)
    deps.extend(data.get('project', {}).get('dependencies', []))

if not deps and setup_py.exists():
    import re
    content = setup_py.read_text()
    m = re.search(r'install_requires\s*=\s*\[(.*?)\]', content, re.DOTALL)
    if m:
        deps.extend(re.findall(r'\"([^\"]+)\"|\'([^\']+)\'', m.group(1)))
        deps = [d[0] or d[1] for d in deps]

for d in deps:
    print(d)
") 2>&1; then
        echo ""
        echo "PUSH BLOCKED: Security vulnerabilities found in dependencies."
        echo "Fix the issues above before pushing."
        exit 1
    fi
else
    echo "WARNING: No pyproject.toml or setup.py found. Skipping audit."
fi

echo "==> Security audit passed. Proceeding with push."
exit 0
